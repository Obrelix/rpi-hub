<%- include('layout') %>

<h1 class="page-title">Settings</h1>

<% if (success) { %>
<div class="alert alert-success"><%= success %></div>
<% } %>
<% if (error) { %>
<div class="alert alert-error"><%= error %></div>
<% } %>

<!-- ── Hub Configuration ─────────────────────────────────────────── -->
<div class="card">
  <div class="card-title">Hub Configuration</div>
  <form method="POST" action="/settings/hub">
    <table class="info-table">
      <tr>
        <th><label for="cfg-port">Port</label></th>
        <td>
          <input id="cfg-port" class="input" type="number" name="port"
                 value="<%= config.port || 3000 %>" min="1" max="65535" required>
          <span class="text-muted" style="font-size:.8rem;margin-left:.5rem;">Requires server restart to take effect</span>
        </td>
      </tr>
      <tr>
        <th><label for="cfg-stats">Stats Interval (ms)</label></th>
        <td>
          <input id="cfg-stats" class="input" type="number" name="statsIntervalMs"
                 value="<%= config.statsIntervalMs || 2000 %>" min="100" required>
        </td>
      </tr>
      <tr>
        <th><label for="cfg-upload">Max Upload Size (MB)</label></th>
        <td>
          <input id="cfg-upload" class="input" type="number" name="maxUploadSizeMb"
                 value="<%= config.maxUploadSizeMb || 50 %>" min="1" required>
        </td>
      </tr>
    </table>
    <div style="margin-top:1rem">
      <button class="btn btn-primary" type="submit">Save Hub Config</button>
    </div>
  </form>
</div>

<!-- ── Service Registry ──────────────────────────────────────────── -->
<div class="section-heading">Service Registry</div>

<% services.forEach(function(svc) { %>
<div class="card">
  <details>
    <summary class="card-title" style="cursor:pointer;list-style:none">
      <%= svc.name %> <span class="text-muted" style="font-size:.8rem;font-weight:normal;">(<%= svc.id %>)</span>
    </summary>
    <form method="POST" action="/settings/services/update/<%= svc.id %>" style="margin-top:1rem">
      <table class="info-table">
        <tr>
          <th><label>Name</label></th>
          <td><input class="input" type="text" name="name" value="<%= svc.name %>" required></td>
        </tr>
        <tr>
          <th><label>Unit</label></th>
          <td><input class="input" type="text" name="unit" value="<%= svc.unit %>" required></td>
        </tr>
        <tr>
          <th><label>Deploy Path</label></th>
          <td><input class="input" type="text" name="deployPath" value="<%= svc.deployPath || '' %>"></td>
        </tr>
        <tr>
          <th><label>Repository</label></th>
          <td><input class="input" type="text" name="repo" value="<%= svc.repo || '' %>"></td>
        </tr>
        <tr>
          <th><label>Config File</label></th>
          <td><input class="input" type="text" name="configFile" value="<%= svc.configFile || '' %>"></td>
        </tr>
        <tr>
          <th><label>Group</label></th>
          <td><input class="input" type="text" name="group" value="<%= svc.group || '' %>"></td>
        </tr>
        <tr>
          <th><label>Description</label></th>
          <td><input class="input" type="text" name="description" value="<%= svc.description || '' %>"></td>
        </tr>
      </table>
      <div style="margin-top:1rem;display:flex;gap:.5rem">
        <button class="btn btn-primary btn-sm" type="submit">Save</button>
      </div>
    </form>
    <form method="POST" action="/settings/services/remove/<%= svc.id %>"
          style="margin-top:.5rem"
          onsubmit="return confirm('Remove service <%= svc.name %>?')">
      <button class="btn btn-danger btn-sm" type="submit">Remove Service</button>
    </form>
  </details>
</div>
<% }); %>

<!-- Add New Service -->
<div class="card">
  <details>
    <summary class="card-title" style="cursor:pointer;list-style:none">Add New Service</summary>
    <form method="POST" action="/settings/services/add" style="margin-top:1rem">
      <table class="info-table">
        <tr>
          <th><label>ID <span class="text-muted">(unique key)</span></label></th>
          <td><input class="input" type="text" name="id" placeholder="my-service" required></td>
        </tr>
        <tr>
          <th><label>Name</label></th>
          <td><input class="input" type="text" name="name" placeholder="My Service" required></td>
        </tr>
        <tr>
          <th><label>Unit</label></th>
          <td><input class="input" type="text" name="unit" placeholder="my-service.service" required></td>
        </tr>
        <tr>
          <th><label>Deploy Path</label></th>
          <td><input class="input" type="text" name="deployPath" placeholder="/home/pi/my-service"></td>
        </tr>
        <tr>
          <th><label>Repository</label></th>
          <td><input class="input" type="text" name="repo" placeholder="https://github.com/…"></td>
        </tr>
        <tr>
          <th><label>Config File</label></th>
          <td><input class="input" type="text" name="configFile" placeholder="/home/pi/my-service/config.yaml"></td>
        </tr>
        <tr>
          <th><label>Group</label></th>
          <td><input class="input" type="text" name="group" placeholder="led-panel"></td>
        </tr>
        <tr>
          <th><label>Description</label></th>
          <td><input class="input" type="text" name="description"></td>
        </tr>
      </table>
      <div style="margin-top:1rem">
        <button class="btn btn-success btn-sm" type="submit">Add Service</button>
      </div>
    </form>
  </details>
</div>

<!-- ── Service Config Files ──────────────────────────────────────── -->
<% const configServices = services.filter(function(s) { return s.configFile; }); %>
<% if (configServices.length > 0) { %>
<div class="section-heading">Service Config Files</div>

<% configServices.forEach(function(svc) { %>
<div class="card">
  <div class="card-title"><%= svc.name %> — <code style="font-size:.85em"><%= svc.configFile %></code></div>
  <form method="POST" action="/settings/config/<%= svc.id %>">
    <% if (svc.configContent !== null) { %>
    <textarea class="input" name="content" rows="12"
              style="width:100%;font-family:monospace;font-size:.85rem;resize:vertical"><%= svc.configContent %></textarea>
    <% } else { %>
    <p class="text-muted">Could not read file (does not exist or no permission).</p>
    <textarea class="input" name="content" rows="12"
              style="width:100%;font-family:monospace;font-size:.85rem;resize:vertical"></textarea>
    <% } %>
    <div style="margin-top:.5rem">
      <button class="btn btn-primary btn-sm" type="submit">Save Config File</button>
    </div>
  </form>
</div>
<% }); %>
<% } %>

<%- include('partials/footer') %>
