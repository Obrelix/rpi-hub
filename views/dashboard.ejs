<%- include('layout') %>

<h1 class="page-title">Dashboard</h1>

<!-- ── Stats Bar ─────────────────────────────────────────────────── -->
<div class="stats-bar">

  <div class="stat-card">
    <div class="stat-label">CPU</div>
    <div class="stat-value" id="statCpuValue">—</div>
    <div class="stat-bar">
      <div class="stat-bar-fill" id="statCpuBar"></div>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-label">Temperature</div>
    <div class="stat-value" id="statTempValue">—</div>
    <div class="stat-bar">
      <div class="stat-bar-fill" id="statTempBar"></div>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-label">Memory</div>
    <div class="stat-value" id="statMemValue">—</div>
    <div class="stat-bar">
      <div class="stat-bar-fill" id="statMemBar"></div>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-label">Disk</div>
    <div class="stat-value" id="statDiskValue">—</div>
    <div class="stat-bar">
      <div class="stat-bar-fill" id="statDiskBar"></div>
    </div>
  </div>

</div>

<!-- ── Radio Control Widget ───────────────────────────────────────── -->
<div class="radio-widget" id="radio-widget">
  <div class="radio-header">
    <h3>RPi Radio</h3>
    <span class="radio-status-badge stopped">Offline</span>
  </div>
  <div class="radio-now-playing">
    <div class="radio-station-name">No station</div>
    <div class="radio-track-title"></div>
    <div class="radio-bitrate"></div>
  </div>
  <div class="radio-transport">
    <button class="radio-prev" title="Previous">&#x23EE;</button>
    <button class="radio-play-pause" title="Play/Pause">&#x25B6;</button>
    <button class="radio-next" title="Next">&#x23ED;</button>
  </div>
  <div class="radio-volume-row">
    <label>Volume</label>
    <input type="range" class="radio-volume" min="0" max="100" value="70">
    <span class="radio-volume-label">70%</span>
  </div>
  <div class="radio-selectors">
    <div>
      <label>Station</label>
      <div class="radio-station-row">
        <select class="radio-station-select"></select>
      </div>
    </div>
    <div>
      <label>Mode</label>
      <select class="radio-mode-select">
        <option value="spectrum">Spectrum</option>
        <option value="ticker">Ticker</option>
        <option value="blank">Blank</option>
        <option value="equalizer">Equalizer</option>
        <option value="waveform">Waveform</option>
      </select>
    </div>
  </div>
</div>

<!-- ── Services Grid ─────────────────────────────────────────────── -->
<div class="section-heading">Services</div>

<div class="services-grid">
<% services.forEach(function(svc) {
  const isRunning = svc.active === 'active';
  const isFailed  = svc.active === 'failed';
  const cardClass = isRunning ? 'running' : (isFailed ? 'failed' : '');
  let badgeClass  = 'stopped';
  let badgeLabel  = 'STOPPED';
  if (isRunning) { badgeClass = 'running'; badgeLabel = 'RUNNING'; }
  else if (isFailed) { badgeClass = 'failed'; badgeLabel = 'FAILED'; }
%>
  <div class="service-card <%= cardClass %>" id="svc-<%= svc.id %>">

    <div class="service-header">
      <span class="service-name"><%= svc.name %></span>
      <span class="status-badge <%= badgeClass %>"><%= badgeLabel %></span>
    </div>

    <% if (svc.group) { %>
    <div><span class="group-tag"><%= svc.group %></span></div>
    <% } %>

    <% if (svc.description) { %>
    <p class="service-desc"><%= svc.description %></p>
    <% } %>

    <% if (isRunning && svc.since) { %>
    <div class="service-meta">Active since: <%= svc.since %></div>
    <% } %>

    <div class="service-actions">
      <% if (!isRunning) { %>
      <button class="btn btn-success btn-sm"
              onclick="startService('<%= svc.id %>', this)">
        Start
      </button>
      <% } else { %>
      <button class="btn btn-danger btn-sm"
              onclick="stopService('<%= svc.id %>', this)">
        Stop
      </button>
      <button class="btn btn-secondary btn-sm"
              onclick="restartService('<%= svc.id %>', this)">
        Restart
      </button>
      <% } %>
    </div>

  </div>
<% }); %>
</div>

<%- include('partials/footer') %>
<script src="/js/radio-widget.js"></script>
