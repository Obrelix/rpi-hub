<%- include('layout') %>

<h1 class="page-title">System Info</h1>

<!-- ── General ──────────────────────────────────────────────────────── -->
<div class="card">
  <div class="card-title">General</div>
  <table class="info-table">
    <tr><th>Hostname</th><td><%= hostname %></td></tr>
    <tr><th>OS</th>      <td><%= os %></td></tr>
    <tr><th>Kernel</th>  <td><%= kernel %></td></tr>
    <tr><th>Uptime</th>  <td><%= uptime %></td></tr>
    <tr><th>Node.js</th> <td><%= nodeVersion %></td></tr>
    <tr><th>Python</th>  <td><%= pythonVersion %></td></tr>
  </table>
</div>

<!-- ── CPU ──────────────────────────────────────────────────────────── -->
<div class="card">
  <div class="card-title">CPU</div>
  <table class="info-table">
    <tr><th>Model</th>       <td><%= cpuModel %></td></tr>
    <tr><th>Cores</th>       <td><%= cpuCores %></td></tr>
    <tr><th>Temperature</th> <td><%= temperature !== null ? temperature + ' °C' : 'n/a' %></td></tr>
  </table>
</div>

<!-- ── Memory ───────────────────────────────────────────────────────── -->
<div class="card">
  <div class="card-title">Memory</div>
  <table class="info-table">
    <tr><th>Total</th>     <td><%= memory.totalMb.toFixed(0) %> MB</td></tr>
    <tr><th>Used</th>      <td><%= memory.usedMb.toFixed(0) %> MB (<%= memory.usedPercent %>%)</td></tr>
    <tr><th>Available</th> <td><%= memory.availableMb.toFixed(0) %> MB</td></tr>
  </table>
</div>

<!-- ── Disk ─────────────────────────────────────────────────────────── -->
<div class="card">
  <div class="card-title">Disk</div>
  <% if (disk && disk.length > 0) { %>
  <table class="info-table">
    <thead>
      <tr><th>Mount</th><th>Used</th><th>Total</th><th>Use%</th></tr>
    </thead>
    <tbody>
    <% disk.forEach(function(d) { %>
      <tr>
        <td><%= d.mount %></td>
        <td><%= d.used %></td>
        <td><%= d.size %></td>
        <td><%= d.usedPercent %>%</td>
      </tr>
    <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <p class="text-muted">No disk info available.</p>
  <% } %>
</div>

<!-- ── Network ──────────────────────────────────────────────────────── -->
<div class="card">
  <div class="card-title">Network</div>
  <% if (networkInterfaces && networkInterfaces.length > 0) { %>
  <table class="info-table">
    <thead>
      <tr><th>Interface</th><th>Address</th><th>Family</th></tr>
    </thead>
    <tbody>
    <% networkInterfaces.forEach(function(iface) { %>
      <tr>
        <td><%= iface.name %></td>
        <td><%= iface.address %></td>
        <td><%= iface.family %></td>
      </tr>
    <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <p class="text-muted">No external network interfaces found.</p>
  <% } %>
</div>

<%- include('partials/footer') %>
