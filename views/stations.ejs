<%- include('layout') %>

<!-- ── Now Playing Bar ──────────────────────────────────────────── -->
<div class="now-playing-bar" id="now-playing-bar">
  <div class="np-controls">
    <button class="np-btn" id="npPrev" title="Previous">&#x23EE;</button>
    <button class="np-btn" id="npPlayPause" title="Play/Pause">&#x25B6;</button>
    <button class="np-btn" id="npNext" title="Next">&#x23ED;</button>
  </div>
  <div class="np-info">
    <div class="np-station" id="npStation">No station</div>
    <div class="np-track" id="npTrack"></div>
    <div class="np-meta" id="npMeta"></div>
  </div>
  <div class="np-volume">
    <label>Vol</label>
    <input type="range" id="npVolume" min="0" max="100" value="70">
    <span class="np-volume-val" id="npVolumeVal">70%</span>
  </div>
  <div class="np-mode">
    <select id="npMode">
      <option value="spectrum">Spectrum</option>
      <option value="ticker">Ticker</option>
    </select>
  </div>
  <span class="status-badge stopped" id="npStatusBadge">Offline</span>
</div>

<!-- ── Toolbar ──────────────────────────────────────────────────── -->
<div class="station-toolbar">
  <div class="toolbar-left">
    <h1 class="page-title">Stations</h1>
    <span class="text-muted" id="stationCount">0 stations</span>
  </div>
  <div class="toolbar-right">
    <label class="btn btn-secondary btn-sm">
      Import CSV
      <input type="file" id="importCsv" accept=".csv,.txt,.tsv" hidden>
    </label>
    <button class="btn btn-secondary btn-sm" id="exportCsv">Export CSV</button>
    <button class="btn btn-success btn-sm" id="addStation">+ Add Station</button>
    <button class="btn btn-danger btn-sm" id="removeSelected" disabled>Remove Selected</button>
    <button class="btn btn-primary btn-sm" id="saveStations">Save</button>
  </div>
</div>

<!-- ── Station Table ────────────────────────────────────────────── -->
<div class="station-table-wrap">
  <table class="station-table" id="stationTable">
    <thead>
      <tr>
        <th class="col-drag"></th>
        <th class="col-num">#</th>
        <th class="col-check"><input type="checkbox" id="selectAll" title="Select all"></th>
        <th class="col-play"></th>
        <th class="col-name">Name</th>
        <th class="col-url">URL</th>
        <th class="col-genre">Genre</th>
      </tr>
    </thead>
    <tbody id="stationBody">
    </tbody>
  </table>
  <div class="station-status-bar">
    <span id="statusText">0 stations</span>
    <span>Click name, URL, or genre to edit inline</span>
  </div>
</div>

<%- include('partials/footer') %>
